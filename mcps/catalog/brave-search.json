{
  "id": "brave-search",
  "name": "Brave Search",
  "description": "Privacy-first web and local search using the Brave Search API.",
  "docsUrl": "https://github.com/brave/brave-search-mcp-server",
  "iconBg": "#FB542B",
  "keywords": [
    "search",
    "web"
  ],
  "template": {
    "kind": "stdio",
    "serverName": "brave_search",
    "command": "npx",
    "args": [
      "-y",
      "@brave/brave-search-mcp-server",
      "--transport",
      "stdio"
    ],
    "envFields": [
      {
        "key": "BRAVE_API_KEY",
        "label": "Brave API key",
        "type": "password",
        "required": true
      }
    ]
  }
}
